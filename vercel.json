{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://grapejs-ud54.onrender.com/api/$1"
    },
    {
      "source": "/p/(.*)",
      "destination": "https://grapejs-ud54.onrender.com/p/$1"
    },
    {
      "source": "/f/(.*)",
      "destination": "https://grapejs-ud54.onrender.com/f/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
